# Пример переменных окружения для продакшена
# Скопируйте в .env и заполните значения. НЕ коммитьте .env в git!

# Обязательно: уникальный секретный ключ, не менее 50 символов
# Сгенерируйте: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Режим отладки: 0 для продакшена, 1 только для локальной разработки
DJANGO_DEBUG=0

# Домены, с которых разрешён доступ (через запятую)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Путь к БД (для Docker)
DJANGO_DB_PATH=/app/data/db.sqlite3

# Для HTTPS за прокси: доверенные источники CSRF (через запятую)
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
